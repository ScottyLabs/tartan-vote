APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173
# Comma-separated browser origins allowed by backend and auth-service CORS.
# Example for server host usage:
# CORS_ALLOWED_ORIGINS=http://172.24.148.20:5173,http://172.24.148.20:8080,http://172.24.148.20:3005
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3005
BIND_ADDR=0.0.0.0:8080
DATABASE_URL=postgres://slabs:slabs@localhost:8181/voting_app

# Backend API base used by frontend
VITE_API_BASE=http://localhost:8080

# Better Auth service (Node)
BETTER_AUTH_URL=http://localhost:3005
BETTER_AUTH_BASE_URL=http://localhost:3005/api/auth
VITE_BETTER_AUTH_BASE_URL=http://localhost:3005/api/auth
BETTER_AUTH_PROVIDER_ID=cmu-sso
VITE_BETTER_AUTH_PROVIDER_ID=cmu-sso
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_PORT=3005

# Upstream OIDC provider config used by auth-service
OIDC_ISSUER=https://idp.scottylabs.org/realms/scottylabs
OIDC_CLIENT_ID=voting-app-localhost
OIDC_CLIENT_SECRET=
# Default callback strategy reuses backend callback:
#   {APP_BASE_URL}/auth/callback
# Optional override if your IdP client requires a different pre-registered callback.
# OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
