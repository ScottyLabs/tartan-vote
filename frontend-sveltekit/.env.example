# TartanVote picks up whichever pair is present. The monorepo's root `.env`
# already sets the VITE_* versions; PUBLIC_* are just accepted as aliases.

# --- Preferred (matches the original frontend & monorepo .env) ---
VITE_API_BASE=http://localhost:8080
VITE_BETTER_AUTH_BASE_URL=http://localhost:3005/api/auth
VITE_BETTER_AUTH_PROVIDER_ID=cmu-sso

# --- Alternative (SvelteKit-native prefix, optional) ---
# PUBLIC_API_BASE=
# PUBLIC_BETTER_AUTH_BASE_URL=http://localhost:3005/api/auth
# PUBLIC_BETTER_AUTH_PROVIDER_ID=cmu-sso
